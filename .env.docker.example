# Docker Services Environment Variables
# Copy this to .env.local or use with docker-compose

# ============================================================================
# PostgreSQL
# ============================================================================
POSTGRES_USER=bandanaiera
POSTGRES_PASSWORD=bandanaiera123
POSTGRES_DB=bandanaiera_admin

# ============================================================================
# MinIO (S3-compatible storage)
# ============================================================================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123

# ============================================================================
# App Configuration (for DATABASE_URL with Docker services)
# ============================================================================
# Use this when running Docker services:
DATABASE_URL="postgresql://bandanaiera:bandanaiera123@localhost:5432/bandanaiera_admin?schema=public"

# ============================================================================
# NextAuth
# ============================================================================
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# ============================================================================
# AWS S3 / MinIO Configuration
# ============================================================================
S3_BUCKET="bandanaiera-uploads"
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID="minioadmin"        # Same as MINIO_ROOT_USER
AWS_SECRET_ACCESS_KEY="minioadmin123" # Same as MINIO_ROOT_PASSWORD
MINIO_ENDPOINT="http://localhost:9000"

# ============================================================================
# Optional: CDN URL
# ============================================================================
# CDN_URL="http://localhost:9000/bandanaiera-uploads"
